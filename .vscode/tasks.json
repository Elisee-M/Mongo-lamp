{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ESP32 (dry-run)",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "compile",
                "--fqbn",
                "esp32:esp32:esp32",
                "${workspaceFolder}/board/board.ino",
                "--build-path",
                "${workspaceFolder}/build"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}